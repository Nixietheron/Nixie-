# Supabase (replace with your own project credentials)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
 
# App URL (metadata, wallet logos)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Signed wallet session (SIWE + Solana). Required in production; use a long random string (e.g. openssl rand -hex 32).
AUTH_SECRET=

# Base Builder Codes (ERC-8021). Comma-separated; app defaults to your code if unset.
# https://docs.base.org/base-chain/builder-codes/builder-codes
# NEXT_PUBLIC_BASE_BUILDER_CODES=bc_dln6i1f5

# WalletConnect (RainbowKit: MetaMask mobile, etc.) — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Farcaster account association (from Base Build)
FARCASTER_ACCOUNT_HEADER=
FARCASTER_ACCOUNT_PAYLOAD=
FARCASTER_ACCOUNT_SIGNATURE=

# Admin (optional: restrict admin to this email)
ADMIN_EMAIL=admin@example.com


# Pinata IPFS (admin uploads)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
# Optional: Gateway key for private pins (Pinata dashboard → Gateways → create key).
# Without this, only public pins load; with it, private NSFW pins load via /api/ipfs-image.
# PINATA_GATEWAY_TOKEN=

# x402 / payments — Base (EVM) wallet that receives USDC (e.g. creator/treasury).
# When set, paid content returns 402 until user pays. Base + Solana (CDP) when CDP keys set.
X402_RECIPIENT_WALLET=0xYourRecipientWalletHere

# Solana: both required for "Pay with Solana" to appear in 402. Recipient gets USDC; fee payer is used by CDP to sponsor tx.
# App tries to get fee payer from CDP GET /supported (kinds[].extra.feePayer). If not returned, set it here (base58).
X402_SOLANA_RECIPIENT_WALLET=
X402_SOLANA_FEE_PAYER=

# Solana RPC (optional). App uses https://solana-rpc.publicnode.com by default; set only to override.
# NEXT_PUBLIC_SOLANA_RPC=

# CDP facilitator: verify/settle for Base and Solana. Get keys from https://cdp.coinbase.com
CDP_API_KEY_ID=your_cdp_api_key_id_here
CDP_API_KEY_SECRET=your_cdp_api_key_secret_here
